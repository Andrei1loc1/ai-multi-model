FROM paddlepaddle/paddle:3.3.1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir paddleocr pymupdf fastapi 'uvicorn[standard]' python-multipart httpx

COPY app/ ./app/

EXPOSE 7860

ENV PORT=7860

CMD uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-7860}